{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/table", "destination": "https://table.made-by-ac.com", "permanent": false },
    { "source": "/kitchen", "destination": "https://kitchen.made-by-ac.com", "permanent": false },
    { "source": "/crew", "destination": "https://crew.made-by-ac.com", "permanent": false },
    { "source": "/staff", "destination": "https://crew.made-by-ac.com", "permanent": false }
  ],
  "rewrites": [
    { "source": "/offer", "destination": "/offer.html" },
    { "source": "/ai", "destination": "/ai.html" },
    { "source": "/work", "destination": "/work.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

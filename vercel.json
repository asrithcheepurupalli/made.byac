{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/offer", "destination": "/offer.html" },
    { "source": "/work", "destination": "/work.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
